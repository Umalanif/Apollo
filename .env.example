# Database
DATABASE_URL="file:./dev.db"

# DataImpulse Proxy
PROXY_HOST=gw.dataimpulse.com
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password
PROXY_PORT=10000

# 2Captcha
TWO_CAPTCHA_API_KEY=your_2captcha_api_key

# Browser / diagnostics
APOLLO_BROWSER=edge
BROWSER_LOCALE=en-US
# Example: Europe/London, America/New_York
BROWSER_TIMEZONE_ID=
CLOUDFLARE_PROBE_URL=https://www.cloudflare.com/

# Apollo Account
APOLLO_EMAIL=your_email@example.com
APOLLO_PASSWORD=your_password

# Microsoft OAuth
APOLLO_MS_EMAIL=your_email@example.com
APOLLO_MS_PASSWORD=your_password
